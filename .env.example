# ─────────────────────────────────────────────────────────────────────────
# B&B Global Services — environment variables
# Copy to `.env.local` and fill in the values you want to use.
# Every integration is OPTIONAL and independent. With none configured, the
# contact form still works and submissions are logged server-side.
# ─────────────────────────────────────────────────────────────────────────

# ── Email notifications via Resend (https://resend.com) ──────────────────
# Create an API key and verify your sending domain (bnbglobal.net) in Resend.
RESEND_API_KEY=
# PRIVATE delivery inbox — where lead notifications actually land. This is
# server-side only and never shown on the site, so it's safe to use a
# personal address (e.g. your Gmail). Comma-separate for multiple recipients.
CONTACT_TO_EMAIL=brunodossantos707@gmail.com
# Verified sender. Must be on a domain you've verified in Resend
# (e.g. notifications@bnbglobal.net). For a quick test before verifying a
# domain, Resend allows onboarding@resend.dev to your own signup address.
CONTACT_FROM_EMAIL=notifications@bnbglobal.net

# ── CRM lead capture via HubSpot Forms API ───────────────────────────────
# Found in your HubSpot form's share/embed code.
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=

# ── Generic webhook (Zapier / Make / n8n / internal endpoint) ────────────
# Receives the raw lead JSON on every submission.
CONTACT_WEBHOOK_URL=

# ── Sales outreach agent (scripts/outreach — runs locally, not on Vercel) ─
# Claude API key for AI-personalized emails (falls back to templates if unset).
ANTHROPIC_API_KEY=
# Optional overrides:
OUTREACH_MODEL=claude-opus-4-8
OUTREACH_FROM_NAME=Bruno Dossantos
OUTREACH_FROM_EMAIL=bruno@bnbglobal.net
OUTREACH_REPLY_TO=brunodossantos707@gmail.com
OUTREACH_POSTAL_ADDRESS=B&B Global Services LLC, New Hampshire, USA
OUTREACH_DAILY_LIMIT=30

# ── Analytics (optional, client-side) ────────────────────────────────────
# Google Analytics 4 measurement ID.
NEXT_PUBLIC_GA_ID=
# PostHog project API key (and optional host; defaults to US cloud).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
